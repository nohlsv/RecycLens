    <!-- Game instructions / info -->
    <string name="street_intro">Nagsimula na ang street cleanup game. I-drag ang bawat basura sa tamang basurahan. Ang nabubulok ay sa green bin, at ang di-nabubulok ay sa blue bin. Linisin ang kalsada bago maubos ang oras.</string>
    <string name="street_intro_en">Street cleanup game started. Drag each trash item into the correct bin. Biodegradable trash goes into the green bin, and non biodegradable trash goes into the blue bin. Clean the street before the time runs out.</string>
    <string name="street_intro_tl">Nagsimula na ang street cleanup game. I-drag ang bawat basura sa tamang basurahan. Ang nabubulok ay sa green bin, at ang di-nabubulok ay sa blue bin. Linisin ang kalsada bago maubos ang oras.</string>
    <string name="street_result_success_speech">Magaling! Natapos mo ang %1$s level na may %2$d tama at %3$d mali. May natitira ka pang %4$d segundo.</string>
    <string name="street_result_success_speech_en">Good work! You finished the %1$s level with %2$d correct and %3$d wrong. You had %4$d seconds left.</string>
    <string name="street_result_success_speech_tl">Magaling! Natapos mo ang %1$s level na may %2$d tama at %3$d mali. May natitira ka pang %4$d segundo.</string>
    <string name="street_result_fail_time_speech">Ay naku. Ubos na ang oras. May %1$d tama at %2$d mali ka. Subukan ulit at linisin ang lahat bago maubos ang oras.</string>
    <string name="street_result_fail_time_speech_en">Oh no. Time is up. You got %1$d correct and %2$d wrong. Try again and clean everything before the time runs out.</string>
    <string name="street_result_fail_time_speech_tl">Ay naku. Ubos na ang oras. May %1$d tama at %2$d mali ka. Subukan ulit at linisin ang lahat bago maubos ang oras.</string>
    <string name="street_result_fail_low_speech">Na-sort mo ang lahat ng %1$d item, pero may napunta sa maling basurahan. May %2$d tama at %3$d mali ka. Subukan ulit para tumaas ang score mo.</string>
    <string name="street_result_fail_low_speech_en">You sorted all %1$d items, but some went into the wrong bin. You got %2$d correct and %3$d wrong. Try again to improve your score.</string>
    <string name="street_result_fail_low_speech_tl">Na-sort mo ang lahat ng %1$d item, pero may napunta sa maling basurahan. May %2$d tama at %3$d mali ka. Subukan ulit para tumaas ang score mo.</string>
