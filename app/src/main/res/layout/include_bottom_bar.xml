<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_bar_bg"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp">

    <ImageButton
        android:id="@+id/navScan"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/btn_orange_circle"
        android:src="@drawable/typcn_camera"
        android:contentDescription="@string/cd_open_camera"
        android:scaleType="centerInside"
        android:padding="10dp"
        android:layout_marginStart="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/labelScan"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/labelScan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_scan_trash"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:maxLines="2"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/navScan"
        app:layout_constraintStart_toStartOf="@id/navScan"
        app:layout_constraintEnd_toEndOf="@id/navScan"
        app:layout_constraintBottom_toBottomOf="parent" />


    <ImageView
        android:id="@+id/navPlay"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="48dp"
        android:src="@drawable/play_game"
        android:contentDescription="@string/cd_open_games"
        android:scaleType="centerInside"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toEndOf="@id/navScan"
        app:layout_constraintTop_toTopOf="@id/navScan" />

    <TextView
        android:id="@+id/labelPlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_play_games"
        android:textColor="@android:color/white"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:maxLines="2"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/navPlay"
        app:layout_constraintStart_toStartOf="@id/navPlay"
        app:layout_constraintEnd_toEndOf="@id/navPlay" />


    <RelativeLayout
        android:id="@+id/langToggle"
        android:layout_width="60dp"
        android:layout_height="30dp"
        android:background="@drawable/lang_toggle_knob"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginEnd="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/langText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_en"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"/>

        <View
            android:id="@+id/langKnob"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/lang_toggle_knob"/>
    </RelativeLayout>

    <ImageButton
        android:id="@+id/btnSpeaker"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@android:color/transparent"
        android:src="@drawable/wpf_speaker"
        android:scaleType="centerInside"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/langToggle"
        app:layout_constraintEnd_toEndOf="@id/langToggle"
        app:layout_constraintStart_toStartOf="@id/langToggle"/>

</androidx.constraintlayout.widget.ConstraintLayout>