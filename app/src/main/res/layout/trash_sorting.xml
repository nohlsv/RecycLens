<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="@drawable/trash_sorting_game_background">

    <ImageButton
        android:id="@+id/btnBackTrash"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginStart="12dp"/>

    <TextView
        android:id="@+id/titleTrash"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/label_trash_sorting"
        android:textColor="#1E4D33"
        android:textSize="20sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:ellipsize="end"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="12sp"
        android:autoSizeMaxTextSize="20sp"
        android:autoSizeStepGranularity="1sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnBackTrash"
        app:layout_constraintEnd_toStartOf="@id/btnInfoTrash"
        app:layout_constraintBottom_toBottomOf="@id/btnBackTrash"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"/>

    <ImageButton
        android:id="@+id/btnInfoTrash"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_info"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"/>

    <TextView
        android:id="@+id/tvLevel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/label_easy"
        android:textColor="#ffffff"
        android:background="@drawable/label_bar_bg"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/titleTrash"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginStart="12dp"/>

    <!-- Score bar: score text + row of circles -->
    <ImageView
        android:id="@+id/binGreen"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:contentDescription="@string/bin_green_bio"
        android:src="@drawable/green_bin"
        app:layout_constraintBottom_toTopOf="@id/btnStartTrash"
        app:layout_constraintEnd_toStartOf="@id/binBlue"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/binBlue"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="8dp"
        android:contentDescription="@string/bin_blue_non_bio"
        android:src="@drawable/blue_bin"
        app:layout_constraintBottom_toTopOf="@id/btnStartTrash"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/binGreen" />

    <LinearLayout
        android:id="@+id/scoreBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvLevel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/tvScore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_score"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:id="@+id/circleRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Game area placeholder (trash items) -->
    <FrameLayout
        android:id="@+id/gameAreaTrash"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/scoreBar"
        app:layout_constraintBottom_toTopOf="@id/binGreen"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="12dp"/>

    <!-- Bins ABOVE Start Game (green left, blue right) -->

    <!-- Start button BELOW bins -->
    <TextView
        android:id="@+id/btnStartTrash"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/action_start_game"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/yellow_button_bg"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"/>

    <!-- Bottom bar include (added for consistency) -->
    <include
        android:id="@+id/bottomBar"
        layout="@layout/include_bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
