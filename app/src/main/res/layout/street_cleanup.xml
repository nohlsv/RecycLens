<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/street_cleanup_game_flood">

    <ImageButton
        android:id="@+id/btnBackStreet"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginStart="12dp"/>

    <TextView
        android:id="@+id/titleStreet"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Street Cleanup"
        android:textColor="#1E4D33"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnBackStreet"
        app:layout_constraintBottom_toBottomOf="@id/btnBackStreet"
        android:layout_marginStart="8dp"/>

    <ImageButton
        android:id="@+id/btnInfoStreet"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_info"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"/>

    <TextView
        android:id="@+id/tvLevel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Easy"
        android:textColor="#ffffff"
        android:background="@drawable/label_bar_bg"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/titleStreet"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginStart="12dp"/>

    <!-- GAME AREA -->
    <FrameLayout
        android:id="@+id/gameAreaStreet"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvLevel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/binRow"
        android:layout_margin="12dp"/>

    <!-- BIN ROW: GREEN + BLUE BINS ABOVE START GAME -->
    <LinearLayout
        android:id="@+id/binRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/gameAreaStreet"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnStartStreet">

        <ImageView
            android:id="@+id/binGreenStreet"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginEnd="16dp"
            android:src="@drawable/green_bin"
            android:contentDescription="Green bin - Biodegradable"/>

        <ImageView
            android:id="@+id/binBlueStreet"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/blue_bin"
            android:contentDescription="Blue bin - Non-biodegradable"/>
    </LinearLayout>

    <TextView
        android:id="@+id/btnStartStreet"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Start Game"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/yellow_button_bg"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp"/>

    <!-- Bottom bar include (added for consistency) -->
    <include
        android:id="@+id/bottomBar"
        layout="@layout/include_bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
