<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/game_background2">

    <!-- Back arrow -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:padding="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Choose Your\nLevel!"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="@font/fredoka_semibold"
        android:textColor="#ffffff"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginStart="56dp"
        android:layout_marginEnd="16dp" />

    <!-- Cards container -->
    <LinearLayout
        android:id="@+id/levelsWrap"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- EASY -->
        <LinearLayout
            android:id="@+id/btnEasy"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/level_bg_easy"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/leaf" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:text="Easy"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/fredoka_semibold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:text="Learn and play at your own pace!"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>

        <!-- MEDIUM -->
        <LinearLayout
            android:id="@+id/btnMedium"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/level_bg_medium"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/leaf" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:text="Medium"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/fredoka_semibold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:text="Sort a little faster!"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>

        <!-- HARD -->
        <LinearLayout
            android:id="@+id/btnHard"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:background="@drawable/level_bg_hard"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:foreground="?attr/selectableItemBackground">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/leaf" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:text="Hard"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/fredoka_semibold"
                    android:textColor="#FFFFFF"/>

                <TextView
                    android:text="Test what you've learned!"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom bar include (fixed to bottom) -->
    <include
        android:id="@+id/bottomBar"
        layout="@layout/include_bottom_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
